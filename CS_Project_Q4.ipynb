      ],
      "source": [
        "print(\"Hello user! This is the PisoPeso Program! This will help you save money everyday!\")\n",
        "while True:\n",
        "    try:\n",
        "        Balance = int(input(\"Enter your current money balance: \").replace(',', ''))\n",
        "        break\n",
        "    except ValueError:\n",
        "        print(\"Invalid input. Please enter a numerical value for your balance.\")\n",
        "\n",
        "while True:\n",
        "    try:\n",
        "        Grocery = int(input(\"Enter the amount you spend for groceries: \").replace(',', ''))\n",
        "        break\n",
        "    except ValueError:\n",
        "        print(\"Invalid input. Please enter a numerical value for groceries.\")\n",
        "\n",
        "while True:\n",
        "    try:\n",
        "        Housing = int(input(\"Enter the amount you spend for housing (rent, house payment): \").replace(',', ''))\n",
        "        break\n",
        "    except ValueError:\n",
        "        print(\"Invalid input. Please enter a numerical value for housing.\")\n",
        "\n",
        "while True:\n",
        "    try:\n",
        "        Utilities = int(input(\"Enter the amount you spend for utilities (water, electricity): \").replace(',', ''))\n",
        "        break\n",
        "    except ValueError:\n",
        "        print(\"Invalid input. Please enter a numerical value for utilities.\")\n",
        "\n",
        "while True:\n",
        "    try:\n",
        "        Transportation = int(input(\"Enter your amount you spend for transportation (gas, taxi ride): \").replace(',', ''))\n",
        "        break\n",
        "    except ValueError:\n",
        "        print(\"Invalid input. Please enter a numerical value for transportation.\")\n",
        "\n",
        "while True:\n",
        "    try:\n",
        "        Healthcare = int(input(\"Enter the amount you spend for healthcare (check-ups, vitamins): \").replace(',', ''))\n",
        "        break\n",
        "    except ValueError:\n",
        "        print(\"Invalid input. Please enter a numerical value for healthcare.\")\n",
        "\n",
        "while True:\n",
        "    try:\n",
        "        Other_Needs = int(input(\"Enter the amount you spend for other needs: \").replace(',', ''))\n",
        "        break\n",
        "    except ValueError:\n",
        "        print(\"Invalid input. Please enter a numerical value for other needs.\")\n",
        "\n",
        "Remaining_Balance = Balance - (Grocery + Housing + Utilities + Transportation + Healthcare + Other_Needs)\n",
        "print(f\"Your current balance now is PHP {Remaining_Balance}\")\n",
        "if Remaining_Balance <= 0:\n",
        "    print(\"Sorry, you officially ran out of money and are now officially broke. Time to budget smarter and earn more!\")\n",
        "else:\n",
        "    while True:\n",
        "        try:\n",
        "            Wants = int(input(\"Enter the amount you spend for the things you want (toys, games): \").replace(',', ''))\n",
        "            break\n",
        "        except ValueError:\n",
        "            print(\"Invalid input. Please enter a numerical value for wants.\")\n",
        "    Final_Balance = Remaining_Balance - Wants\n",
        "    if Final_Balance <= 0:\n",
        "        print(\"Sorry, you officially ran out of money and are now officially broke. Time to budget smarter and earn more!\")\n",
        "    else:\n",
        "        print(f\"Your current balance now is PHP {Final_Balance}. Congrats! You can budget your money efficiently!\")"
